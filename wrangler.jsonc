{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "foss-radar",
	"compatibility_date": "2026-03-04",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "./worker/index.ts",
	"assets": {
		"directory": "dist/client",
		"not_found_handling": "none",
		"binding": "ASSETS"
	},
	"images": {
		"binding": "IMAGES"
	},
	"kv_namespaces": [
		{
			"binding": "VINEXT_CACHE",
			"id": "430fe9a8755841058eace365f290993a"
		}
	]
}